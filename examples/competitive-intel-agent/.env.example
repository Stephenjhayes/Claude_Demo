# Copy this to .env and fill in your keys — never commit .env to git

# ── Required ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Firehose (https://firehose.com) — FREE, primary data source ───────────────
# Step 1: Sign up at firehose.com, get your management key (fhm_...)
FIREHOSE_MGMT_KEY=fhm_...
# Step 2: Run `python main.py --bootstrap` — it prints your tap token
FIREHOSE_TAP_TOKEN=fh_...
# Optional: override the tap name (default: guidewire-ci)
# FIREHOSE_TAP_NAME=guidewire-ci
# Optional: replay window (default 24h, max 24h)
# FIREHOSE_SINCE=24h
# FIREHOSE_MAX_EVENTS=5000

# ── Firecrawl (https://firecrawl.dev) — deep page scraping ───────────────────
# Used for product pages and careers scraping (optional but recommended)
FIRECRAWL_API_KEY=fc-...

# ── NewsAPI (https://newsapi.org) — extra news coverage ──────────────────────
# Optional — Firehose already covers most news sources via Ahrefs crawler
NEWS_API_KEY=...

# ── Storage overrides (optional) ──────────────────────────────────────────────
# INTEL_DB_PATH=./competitive_intel.db
# REPORTS_DIR=./reports
